# =============================================
# ClasesYa - Variables de entorno
# Copia este archivo como .env y completa los valores
# =============================================

# Base de datos (la URL debe apuntar al servicio "postgres" del docker-compose)
DATABASE_URL=postgresql://usuario:password@postgres:5432/clasesya
POSTGRES_USER=usuario
POSTGRES_PASSWORD=password
POSTGRES_DB=clasesya

# Secretos de autenticación (genera valores seguros con: openssl rand -base64 32)
JWT_SECRET=clave_secreta_aqui

# URL pública de la app (reemplaza con la IP de tu VPS)
NEXT_PUBLIC_URL=http://158.220.119.167:3000

# Entorno
NODE_ENV=production
